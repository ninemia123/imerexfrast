        <div class="repo-transfer-row"><span>ΣΥΝΟΛΟ ΩΡΩΝ ΜΗΝΑ:</span><span id="total-month-hours" style="font-size:18px">0.0</span></div>
    </div>

    <table id="cal-table"><thead><tr><th>ΔΕ</th><th>ΤΡ</th><th>ΤΕ</th><th>ΠΕ</th><th>ΠΑ</th><th>ΣΑ</th><th>ΚΥ</th></tr></thead><tbody id="cal-body"></tbody></table>
    
    <div class="footer">
