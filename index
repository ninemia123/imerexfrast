    auth.signInWithPopup(provider).catch(error => { alert("Σφάλμα: " + error.message); });
}

function showLoginModal() { document.getElementById('loginModal').style.display = 'flex'; isLoginMode = true; document.getElementById('loginTitle').innerText = 'Σύνδεση'; document.getElementById('loginActionBtn').innerText = 'Σύνδεση'; document.querySelector('.toggle-mode').innerHTML = 'Δεν έχετε λογαριασμό; Εγγραφή'; document.getElementById('loginError').innerText = ''; document.getElementById('loginEmail').value = ''; document.getElementById('loginPassword').value = ''; }
function closeLoginModal() { document.getElementById('loginModal').style.display = 'none'; }
function toggleLoginMode() { isLoginMode = !isLoginMode; if (isLoginMode) { document.getElementById('loginTitle').innerText = 'Σύνδεση'; document.getElementById('loginActionBtn').innerText = 'Σύνδεση'; document.querySelector('.toggle-mode').innerHTML = 'Δεν έχετε λογαριασμό; Εγγραφή'; } else { document.getElementById('loginTitle').innerText = 'Εγγραφή'; document.getElementById('loginActionBtn').innerText = 'Εγγραφή'; document.querySelector('.toggle-mode').innerHTML = 'Έχετε ήδη λογαριασμό; Σύνδεση'; } document.getElementById('loginError').innerText = ''; }

document.getElementById('loginActionBtn').onclick = () => {
    const email = document.getElementById('loginEmail').value;
    const password = document.getElementById('loginPassword').value;
    if (!email || !password) { document.getElementById('loginError').innerText = 'Συμπληρώστε email και κωδικό'; return; }
    if (isLoginMode) { auth.signInWithEmailAndPassword(email, password).then(() => { closeLoginModal(); }).catch(err => { document.getElementById('loginError').innerText = err.message; }); }
    else { auth.createUserWithEmailAndPassword(email, password).then(() => { closeLoginModal(); }).catch(err => { document.getElementById('loginError').innerText = err.message; }); }
};
document.getElementById('registerBtn').onclick = () => { if (!isLoginMode) document.getElementById('loginActionBtn').click(); else toggleLoginMode(); };
function logout() { auth.signOut(); }

async function syncToCloud() {
    if (!currentUser) { alert("Παρακαλώ συνδεθείτε πρώτα!"); return; }
    const syncBtn = document.getElementById('cloudSyncBtn');
    const originalText = syncBtn.innerText;
    syncBtn.disabled = true;
    syncBtn.innerText = "Συγχρονισμός...";
    document.getElementById('syncStatus').innerText = "Αποθήκευση στο cloud...";
    try {
        await performSync(true);
    } catch(e) {
        document.getElementById('syncStatus').innerHTML = "❌ Σφάλμα: " + e.message;
        if(e.message.includes("permission")) alert("Σφάλμα δικαιωμάτων: Πρέπει να αλλάξετε τους κανόνες ασφαλείας στο Firestore!");
    } finally {
        syncBtn.disabled = false;
        syncBtn.innerText = originalText;
    }
}

// ============ ΔΕΝ ΥΠΑΡΧΕΙ ΑΥΤΟΜΑΤΟ ΦΟΡΤΩΜΑ ΑΠΟ CLOUD ============
function updateAuthUI(user) {
    currentUser = user;
    if (user) {
        document.getElementById('userEmail').innerText = user.email;
        document.getElementById('userAvatar').innerText = (user.email || 'U').charAt(0).toUpperCase();
        document.getElementById('googleBtn').style.display = 'none';
        document.getElementById('emailBtn').style.display = 'none';
        document.getElementById('logoutBtn').style.display = 'inline-block';
        showLastCloudBackup();
    } else {
        document.getElementById('userEmail').innerText = "Μη συνδεδεμένος";
        document.getElementById('userAvatar').innerText = "?";
        document.getElementById('googleBtn').style.display = 'inline-block';
        document.getElementById('emailBtn').style.display = 'inline-block';
        document.getElementById('logoutBtn').style.display = 'none';
        document.getElementById('lastBackupSpan').innerHTML = "";
    }
}
auth.onAuthStateChanged(user => { updateAuthUI(user); });

function checkForAppUpdate() { const savedVersion = localStorage.getItem('app_version'); if (savedVersion && savedVersion !== APP_VERSION) { document.getElementById('version-status').innerHTML = `Νέα έκδοση ${APP_VERSION} διαθέσιμη!`; if ('caches' in window) caches.keys().then(keys => { keys.forEach(key => { if (key.includes('imerast')) caches.delete(key); }); }); setTimeout(() => window.location.reload(), 1500); return true; } document.getElementById('version-status').innerHTML = `Έκδοση ${APP_VERSION} | Ενημερωμένο`; return false; }
function manualUpdate() { document.getElementById('version-status').innerHTML = 'Έλεγχος...'; window.location.reload(); }
if ('serviceWorker' in navigator) { navigator.serviceWorker.register(`./service-worker.js?v=${APP_VERSION}`).then(reg => { console.log('SW registered'); setInterval(() => reg.update(), 60*60*1000); }).catch(err => console.log(err)); }
document.addEventListener('DOMContentLoaded', () => { document.getElementById('mode-sel').value = settings.mode; calculate(); checkForAppUpdate(); });
</script>
