// ============ ΒΕΛΤΙΩΜΕΝΟ AUTO SYNC (ΧΩΡΙΣ MERGE) ============
async function performSync(showMessage = false) {
    if (!currentUser || isRestoring) return;
    
    try {
        const userDoc = dbFirestore.collection('userData').doc(currentUser.uid);
        // ΧΩΡΙΣ merge: true - ΑΝΤΙΚΑΤΑΣΤΑΣΗ ολόκληρου του db
        await userDoc.set({ 
            db: db,
            settings: settings, 
            repStorage: repStorage, 
            extraPents: extraPents,
            lastUpdated: firebase.firestore.FieldValue.serverTimestamp() 
        });
        
        if (showMessage) {
            const syncDiv = document.getElementById('syncStatus');
            syncDiv.innerHTML = "✓ Αποθηκεύτηκε στο cloud!";
            syncDiv.style.color = "#4caf50";
            setTimeout(() => {
                if (syncDiv) syncDiv.innerHTML = "";
            }, 2000);
        }
        
        showLastCloudBackup();
    } catch(e) {
        console.error("Sync error:", e);
        if (showMessage) {
            const syncDiv = document.getElementById('syncStatus');
            syncDiv.innerHTML = "⚠️ Σφάλμα: " + e.message;
            syncDiv.style.color = "#ff9800";
            setTimeout(() => {
                if (syncDiv) syncDiv.innerHTML = "";
            }, 3000);
        }
    }
}

async function autoSyncToCloud(showMessage = false, immediate = false) {
    if (!currentUser || isRestoring) return;
    
    if (immediate) {
        if (autoSyncTimeout) clearTimeout(autoSyncTimeout);
        await performSync(showMessage);
        return;
    }
    
    if (autoSyncTimeout) clearTimeout(autoSyncTimeout);
    autoSyncTimeout = setTimeout(async () => {
        await performSync(showMessage);
    }, 500);
}

// ============ ΛΕΙΤΟΥΡΓΙΕΣ RESTORE & CLEANUP ============

async function showLastCloudBackup() {
    if (!currentUser) return;
    try {
        const doc = await dbFirestore.collection('userData').doc(currentUser.uid).get();
        if (doc.exists && doc.data().lastUpdated) {
            const lastUpdate = doc.data().lastUpdated.toDate();
            const formattedDate = lastUpdate.toLocaleDateString('el-GR') + ' ' + lastUpdate.toLocaleTimeString('el-GR', {hour:'2-digit', minute:'2-digit'});
            const span = document.getElementById('lastBackupSpan');
            if (span) span.innerHTML = `📅 ${formattedDate}`;
        } else {
            const span = document.getElementById('lastBackupSpan');
            if (span) span.innerHTML = "";
        }
    } catch(e) { console.log("Cannot get last backup date", e); }
}

async function restoreFromCloud() {
    if (!currentUser) {
        alert("Παρακαλώ συνδεθείτε πρώτα!");
        return;
    }
    
    if (!confirm("⚠️ ΠΡΟΣΟΧΗ! Η επαναφορά από το cloud θα ΑΝΤΙΚΑΤΑΣΤΗΣΕΙ όλα τα τοπικά δεδομένα.\n\n✅ Οι βάρδιες, οι ρυθμίσεις και οι μεταφορές θα αντικατασταθούν.\n❌ Τα τρέχοντα δεδομένα θα χαθούν.\n\nΘέλετε να συνεχίσετε;")) {
        return;
    }
    
    if (!confirm("ΤΕΛΕΥΤΑΙΑ ΕΥΚΑΙΡΙΑ: Να κάνω αυτόματο backup των τρεχόντων δεδομένων;")) {
        performRestore();
    } else {
        exportData();
        setTimeout(() => {
            if (confirm("Το backup δημιουργήθηκε. Θέλετε να συνεχίσετε με την επαναφορά;")) {
                performRestore();
            }
        }, 1000);
    }
}

async function performRestore() {
    const restoreBtn = document.querySelector('.btn-restore');
    const originalText = restoreBtn.innerText;
    restoreBtn.disabled = true;
    restoreBtn.innerText = "⏳ Επαναφορά...";
    isRestoring = true;
    
    try {
        const doc = await dbFirestore.collection('userData').doc(currentUser.uid).get();
        
        if (!doc.exists) {
            alert("❌ Δεν βρέθηκαν αποθηκευμένα δεδομένα στο cloud για αυτόν τον λογαριασμό!");
            restoreBtn.disabled = false;
            restoreBtn.innerText = originalText;
            isRestoring = false;
            return;
        }
        
        const data = doc.data();
        let restoredCount = 0;
        
        if (data.db) { db = JSON.parse(JSON.stringify(data.db)); localStorage.setItem('exfroura_db', JSON.stringify(db)); restoredCount++; }
        if (data.settings) { settings = JSON.parse(JSON.stringify(data.settings)); localStorage.setItem('exfroura_settings', JSON.stringify(settings)); document.getElementById('mode-sel').value = settings.mode || "32"; restoredCount++; }
        if (data.repStorage) { repStorage = JSON.parse(JSON.stringify(data.repStorage)); localStorage.setItem('exfroura_rep', JSON.stringify(repStorage)); restoredCount++; }
        if (data.extraPents) { extraPents = JSON.parse(JSON.stringify(data.extraPents)); localStorage.setItem('exfroura_extra_pents', JSON.stringify(extraPents)); restoredCount++; }
        
        calculate();
        
        const syncDiv = document.getElementById('syncStatus');
        syncDiv.innerHTML = `✅ Επαναφορά από cloud ολοκληρώθηκε! (${restoredCount} κατηγορίες)`;
        syncDiv.style.color = "#4caf50";
        setTimeout(() => { syncDiv.innerHTML = ""; syncDiv.style.color = ""; }, 4000);
        alert("✅ Η επαναφορά ολοκληρώθηκε επιτυχώς!");
        
    } catch(e) {
        document.getElementById('syncStatus').innerHTML = "❌ Σφάλμα επαναφοράς: " + e.message;
        alert("❌ Σφάλμα κατά την επαναφορά: " + e.message);
    } finally {
        restoreBtn.disabled = false;
        restoreBtn.innerText = originalText;
        isRestoring = false;
    }
}

function cleanOldData() {
    if (!confirm("⚠️ ΠΡΟΣΟΧΗ! Αυτή η ενέργεια θα διαγράψει ΟΛΕΣ τις βάρδιες παλαιότερες των 3 ετών.\n\n✅ Οι μηνιαίες μεταφορές (repStorage) θα παραμείνουν.\n❌ Οι παλιές βάρδιες θα χαθούν ΟΡΙΣΤΙΚΑ.\n\nΣυνιστάται να κάνετε πρώτα Εξαγωγή Backup.\n\nΘέλετε να συνεχίσετε;")) {
        return;
    }
    
    if (!confirm("ΤΕΛΕΥΤΑΙΑ ΕΥΚΑΙΡΙΑ: Να κάνω αυτόματο backup πριν διαγράψω;")) {
        if (!confirm("Είστε απόλυτα σίγουροι; Η διαγραφή είναι ΟΡΙΣΤΙΚΗ!")) {
            return;
        }
    } else {
        exportData();
        alert("✅ Δημιουργήθηκε backup. Συνεχίζεται ο καθαρισμός...");
    }
    
    const threeYearsAgo = new Date();
    threeYearsAgo.setFullYear(threeYearsAgo.getFullYear() - 3);
    
    let cleaned = 0;
    for (let key in db) {
        if (key.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const date = new Date(key);
            if (date < threeYearsAgo) {
                delete db[key];
                cleaned++;
            }
        }
    }
    
    localStorage.setItem('exfroura_db', JSON.stringify(db));
    alert(`✅ Αφαιρέθηκαν ${cleaned} παλιές εγγραφές`);
    calculate();
    autoSyncToCloud(true, true);
}

// ============ ΥΠΑΡΧΟΥΣΕΣ ΛΕΙΤΟΥΡΓΙΕΣ ============

function isWork(s) { if (!s) return false; return ['ΠΡΩΙ', 'ΑΠΟΓΕΥΜΑ', 'ΝΥΧΤΑ (3.3€)', 'ΡΕΠΟ (10ο ΠΕΝΘ)'].includes(s) || s.startsWith("[C]"); }
function isPentShift(s) { if (!s) return false; return (isWork(s) || s === 'ΑΔΙΑΘΕΤΟ' || s === 'ΑΔΙΑΘΕΤΟ (ΑΡΓΙΑΣ)') && s !== 'ΡΕΠΟ (10ο ΠΕΝΘ)'; }
function getTagClass(type, name) { if (name && name.startsWith("[C]")) return "tag-custom"; if (type === 'morning') return "tag-morning"; if (type === 'afternoon') return "tag-afternoon"; if (type === 'night') return "tag-night"; if (type === 'repo10') return "tag-repo10"; if (type === 'leave') return "tag-leave"; if (type === 'rest') return "tag-rest"; return "tag-custom"; }
function fmt(d) { return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`; }

function getHols(y) { let h = [fmt(new Date(y,0,1)), fmt(new Date(y,0,6)), fmt(new Date(y,2,25)), fmt(new Date(y,4,1)), fmt(new Date(y,7,15)), fmt(new Date(y,9,28)), fmt(new Date(y,11,25)), fmt(new Date(y,11,26))]; let a=y%19, d=(19*a+15)%30, e=(2*(y%4)+4*(y%7)+6*d+6)%7; let p=d+e+22+13; let m=3, day=p; if(day>31){day-=31; m=4;} if(day>30){day-=30; m=5;} let easter = new Date(y, m-1, day); const add = (o) => { let x=new Date(easter); x.setDate(easter.getDate()+o); h.push(fmt(x)); }; add(-48); add(-2); add(1); add(50); return h; }

function checkHasPent(dStr) { let data = db[dStr]; if (!data) return false; let d = new Date(dStr); let dw = d.getDay(); if ([data.t1, data.t2, data.t3].includes('ΡΕΠΟ (10ο ΠΕΝΘ)')) return false; if (dw === 6) return isPentShift(data.t1) || isPentShift(data.t2) || isPentShift(data.t3); if (dw === 0) { if (!(isWork(data.t1) || isWork(data.t2) || isWork(data.t3) || data.t1 === 'ΑΔΙΑΘΕΤΟ (ΑΡΓΙΑΣ)')) return false; let prev = new Date(d); prev.setDate(d.getDate() - 1); if (checkHasPent(fmt(prev))) return false; return true; } return false; }

function calculate() { 
    const y = cur.getFullYear(), m = cur.getMonth(), hols = getHols(y);
    document.getElementById('month-label').innerText = new Intl.DateTimeFormat('el-GR', {month:'short', year:'numeric'}).format(cur).toUpperCase();
    let days = new Date(y, m + 1, 0).getDate();
    let startDayIdx = (new Date(y, m, 1).getDay() + 6) % 7;
    let allDays = [];
    for(let d=1; d<=days; d++) { let dStr = fmt(new Date(y, m, d)); allDays.push({ dStr, date: new Date(y,m,d), dw: new Date(y,m,d).getDay(), isH: hols.includes(dStr), data: db[dStr]||{}, hasPent: false, hasRepo: false }); }
    let mTarget = 0, mNight = 0, mPent = 0, mActualTotal = 0, totalRepoFromWeekends = 0;
    let leaves = {'ΚΑΝΟΝΙΚΗ ΑΔΕΙΑ':0, 'ΒΡΑΧΕΙΑ':0, 'ΑΝΑΡΡΩΤΙΚΗ':0, 'ΕΙΔΙΚΗ ΑΔΕΙΑ':0};
    let baseWeekly = parseInt(settings.mode); let reduced = document.getElementById('reduced-select').value;
    if(reduced==='minus1') baseWeekly -= 5; else if(reduced==='minus2') baseWeekly -= 10;
    const dailyRate = baseWeekly / 5;
    let weeksHtml = '', currentWeekTarget = 0, currentWeekActual = 0, weekCount = 1;
    allDays.forEach((d, idx) => { let isLeaveDay = [d.data.t1, d.data.t2, d.data.t3].some(l => leaves.hasOwnProperty(l)); let dayTarget = (d.dw >= 1 && d.dw <= 5 && !isLeaveDay) ? dailyRate : 0; let dayActual = 0; [1,2,3].forEach(n => { let shiftName = d.data[`t${n}`]; if (isWork(shiftName)) { let h = parseFloat(d.data[`h${n}`]||0); dayActual += h; if (d.data[`type${n}`]==='night') mNight += h; } if (leaves.hasOwnProperty(shiftName)) leaves[shiftName]++; }); mTarget += dayTarget; mActualTotal += dayActual; currentWeekTarget += dayTarget; currentWeekActual += dayActual; if (d.dw === 0 || idx === allDays.length - 1) { weeksHtml += `<div class="w-tile">ΕΒΔ ${weekCount}<br><span class="w-val">ΣΤ: ${currentWeekTarget.toFixed(1)}</span><span class="w-diff">Δ: ${(currentWeekActual - currentWeekTarget).toFixed(1)}</span></div>`; currentWeekTarget = 0; currentWeekActual = 0; weekCount++; } d.hasPent = checkHasPent(d.dStr); if (d.hasPent) mPent++; let isActiveOnRepoDay = (isWork(d.data.t1) || isWork(d.data.t2) || isWork(d.data.t3) || d.data.t1 === 'ΑΔΙΑΘΕΤΟ (ΑΡΓΙΑΣ)'); if (d.dw === 0 && isActiveOnRepoDay) { if (!d.hasPent) { d.hasRepo = true; totalRepoFromWeekends += 8; } } if (d.isH && d.dw >= 1 && d.dw <= 5 && isActiveOnRepoDay) { d.hasRepo = true; totalRepoFromWeekends += 8; } });
    let pk = cur.getFullYear() + '-' + String(cur.getMonth()+1).padStart(2,'0');
    let currentExtra = extraPents[pk] || 0; let totalPent = mPent + currentExtra; let extraPentDeduction = currentExtra * 8;
    document.getElementById('weeks-stats').innerHTML = weeksHtml; document.getElementById('m-target').innerText = mTarget.toFixed(1); document.getElementById('m-penthemera').innerText = totalPent; document.getElementById('p-extra-label').innerText = currentExtra > 0 ? `(+${currentExtra} έξτρα)` : ""; document.getElementById('m-night').innerText = mNight.toFixed(1); document.getElementById('m-repo').innerText = (totalRepoFromWeekends/8).toFixed(0); document.getElementById('repo-from-weekends').innerText = totalRepoFromWeekends.toFixed(1); document.getElementById('extra-hours').innerText = (mActualTotal - mTarget).toFixed(1); if (extraPentDeduction > 0) { document.getElementById('extra-pent-deduction-row').style.display = 'flex'; document.getElementById('extra-pent-deduction').innerText = "-" + extraPentDeduction.toFixed(1); } else { document.getElementById('extra-pent-deduction-row').style.display = 'none'; }
    let prev = new Date(y, m-1, 1), prevK = prev.getFullYear() + '-' + String(prev.getMonth()+1).padStart(2,'0'); if (!localStorage.getItem('manual_prmin_'+pk)) { let autoPrev = repStorage.savedTransfers[prevK] || 0; document.getElementById('prminRepInput').value = autoPrev.toFixed(1); } else { document.getElementById('prminRepInput').value = localStorage.getItem('manual_prmin_'+pk); }
    let currentPrmin = parseFloat(document.getElementById('prminRepInput').value) || 0; let paid = parseFloat(localStorage.getItem('paid_'+pk)) || 0; document.getElementById('paidHours').value = paid;
    let totalMonthRes = (mActualTotal - mTarget + totalRepoFromWeekends - extraPentDeduction); document.getElementById('total-month-hours').innerText = totalMonthRes.toFixed(1); document.getElementById('transferRep').innerText = (currentPrmin + totalMonthRes - paid).toFixed(1);
    document.getElementById('leave-normal').innerText = leaves['ΚΑΝΟΝΙΚΗ ΑΔΕΙΑ']; document.getElementById('leave-short').innerText = leaves['ΒΡΑΧΕΙΑ']; document.getElementById('leave-sick').innerText = leaves['ΑΝΑΡΡΩΤΙΚΗ']; document.getElementById('leave-special').innerText = leaves['ΕΙΔΙΚΗ ΑΔΕΙΑ'];
    let pGr = totalPent * 46, pEis = pGr * 0.02, pTax = (pGr - pEis) * 0.20, pNet = pGr - pEis - pTax; document.getElementById('p-count').innerText = totalPent; document.getElementById('p-gross').innerText = pGr.toFixed(2)+'€'; document.getElementById('p-eis').innerText = pEis.toFixed(2)+'€'; document.getElementById('p-tax').innerText = pTax.toFixed(2)+'€'; document.getElementById('p-net').innerText = pNet.toFixed(2)+'€';
    let nGr = mNight * 3.3, nMtpy = nGr * 0.02, nEis = nGr * 0.02, nTax = (nGr - nMtpy - nEis) * 0.20, nNet = nGr - nMtpy - nEis - nTax; document.getElementById('night-gross').innerText = nGr.toFixed(2)+'€'; document.getElementById('night-mtpy').innerText = nMtpy.toFixed(2)+'€'; document.getElementById('night-eisfora').innerText = nEis.toFixed(2)+'€'; document.getElementById('night-tax').innerText = nTax.toFixed(2)+'€'; document.getElementById('night-net').innerText = nNet.toFixed(2)+'€'; document.getElementById('total-net-combined').innerText = (nNet + pNet).toFixed(2)+'€';
    let body = document.getElementById('cal-body'); body.innerHTML = ''; let row = document.createElement('tr'); for(let i=0; i<startDayIdx; i++) row.appendChild(document.createElement('td')); allDays.forEach(d => { if (row.children.length === 7) { body.appendChild(row); row = document.createElement('tr'); } let cell = document.createElement('td'); cell.onclick = () => openModal(d.dStr); if (d.isH) cell.className = 'holiday-cell'; else if (d.dw === 0) cell.className = 'sun-cell'; else if (d.dw === 6) cell.className = 'sat-cell'; let tags = ''; [1,2,3].forEach(n => { if (d.data[`t${n}`]) { let display = d.data[`t${n}`].replace("[C] ", ""); let cls = getTagClass(d.data[`type${n}`], d.data[`t${n}`]); tags += `<div class="shift-tag ${cls}">${display}</div>`; } }); cell.innerHTML = `<div style="display:flex; justify-content:space-between"><span class="day-num">${d.date.getDate()}</span><div style="font-size:9px">${d.hasPent?'<b style="color:orange">46€</b>':''} ${d.hasRepo?'<b style="color:red">+Ρ</b>':''}</div></div>${tags}${d.data.txt?`<div class="day-note">${d.data.txt}</div>`:''}`; row.appendChild(cell); }); body.appendChild(row);
}

