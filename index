        </div>
        <input type="file" id="importFile" style="display:none" onchange="importData(event)">
        
        <button onclick="manualUpdate()" class="update-btn">🔄 Έλεγχος ενημέρωσης</button>
        <div style="text-align: center; margin-top: 10px; font-size: 10px; color: #888;" id="version-status"></div>
    </div>
</div>

<div id="modal" class="modal"><div class="modal-content"><div id="modal-date" style="text-align:center; font-weight:bold; margin-bottom:10px;"></div><div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 5px; margin-bottom: 10px;"><button class="m-btn" onclick="setActiveShift(1)" id="shift1-btn">Βάρδια 1</button><button class="m-btn" onclick="setActiveShift(2)" id="shift2-btn">Βάρδια 2</button><button class="m-btn" onclick="setActiveShift(3)" id="shift3-btn">Βάρδια 3</button></div><div class="m-grid" id="m-opts"></div><hr><div class="shift-row"><input type="text" id="c-n1" readonly><input type="number" id="c-h1" step="0.5"><input type="text" id="c-t1" hidden></div><div class="shift-row"><input type="text" id="c-n2" readonly><input type="number" id="c-h2" step="0.5"><input type="text" id="c-t2" hidden></div><div class="shift-row"><input type="text" id="c-n3" readonly><input type="number" id="c-h3" step="0.5"><input type="text" id="c-t3" hidden></div><input type="text" id="c-txt" placeholder="Σχόλιο..." style="width:100%; padding:10px; margin:10px 0; box-sizing:border-box;"><div style="display:grid; grid-template-columns: 1fr 1fr; gap:5px;"><button onclick="saveDay()" style="padding:15px; background:var(--green); color:white; border:none; border-radius:4px; font-weight:bold;">ΑΠΟΘΗΚΕΥΣΗ</button><button onclick="deleteDay()" style="padding:15px; background:var(--red); color:white; border:none; border-radius:4px; font-weight:bold;">ΔΙΑΓΡΑΦΗ</button></div><button onclick="closeModal()" style="width:100%; padding:10px; background:#ccc; border:none; border-radius:4px; font-weight:bold; margin-top:5px;">ΚΛΕΙΣΙΜΟ</button></div></div>

<script>
const firebaseConfig = {
    apiKey: "AIzaSyAbBDQOY5ECKnSMme08uHNmY6j2Vk-UyQg",
    authDomain: "hmerologioexfr.firebaseapp.com",
    projectId: "hmerologioexfr",
    storageBucket: "hmerologioexfr.firebasestorage.app",
    messagingSenderId: "538946188020",
    appId: "1:538946188020:web:e35072f47590f3fedbe4a1"
};

firebase.initializeApp(firebaseConfig);
const auth = firebase.auth();
const dbFirestore = firebase.firestore();

const APP_VERSION = "7.3";
localStorage.setItem('app_version', APP_VERSION);
document.getElementById('app-title').innerHTML = `ΕΞ. ΦΡΟΥΡΑ - V${APP_VERSION} ✓`;

let cur = new Date();
let db = JSON.parse(localStorage.getItem('exfroura_db') || '{}');
