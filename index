    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore-compat.js"></script>
    
    <style>
        :root { 
            --green: #1b5e20; --blue: #0d47a1; --red: #b71c1c; --gold: #fbc02d; 
            --sat-bg: #e3f2fd; --sun-bg: #ffebee; --hol-bg: #ffcdd2; 
            --purple: #7b1fa2; --orange: #ff9800;
            --cls-morning: #2e7d32;
            --cls-afternoon: #ef6c00;
            --cls-night: #4527a0;
            --cls-repo10: #c62828;
            --cls-leave: #ad1457;
            --cls-rest: #616161;
        }
        body { font-family: Arial, sans-serif; margin: 0; padding: 5px; background: #f0f0f0; user-select: none; }
        .main-card { max-width: 1100px; margin: auto; background: white; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
        .header { background: var(--green); color: white; padding: 10px; }
        .top-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; flex-wrap: wrap; gap: 8px; }
        .header select { font-weight: bold; border-radius: 4px; border: none; padding: 10px; width: 100%; font-size: 14px; margin-top: 4px; background: white; color: black; }
        
        .auth-panel { background: #1565c0; padding: 8px 12px; border-radius: 8px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
        .user-info { display: flex; align-items: center; gap: 10px; color: white; font-size: 12px; font-weight: bold; flex-wrap: wrap; }
        .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: white; display: flex; align-items: center; justify-content: center; color: #1565c0; font-weight: bold; }
        .auth-btn { background: white; border: none; padding: 6px 12px; border-radius: 20px; font-weight: bold; cursor: pointer; color: #1565c0; margin-left: 5px; }
        .auth-btn-google { background: #db4437; color: white; }
        .auth-btn-email { background: #4285f4; color: white; }
        .last-backup { font-size: 9px; opacity: 0.8; margin-left: 5px; }
        
        .login-modal { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); justify-content: center; align-items: center; }
        .login-card { background: white; padding: 20px; border-radius: 12px; max-width: 350px; width: 90%; text-align: center; }
        .login-card input { width: 100%; padding: 10px; margin: 8px 0; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; }
        .login-card button { width: 100%; padding: 10px; margin: 5px 0; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; }
        .toggle-mode { color: #1565c0; cursor: pointer; margin-top: 10px; display: inline-block; }
        .error-msg { color: red; font-size: 12px; margin: 5px 0; }
        
        .month-totals { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; padding: 10px; background: #e8f5e9; border-bottom: 2px solid var(--green); }
        .total-box { background: white; padding: 8px 2px; border-radius: 5px; text-align: center; border: 1px solid #c8e6c9; }
        .total-label { font-size: 9px; font-weight: bold; color: #444; display: block; }
        .total-val { font-size: 14px; font-weight: 900; color: var(--green); }
        
        .rep-container { padding: 8px 10px; background: #e3f2fd; border-bottom: 2px solid var(--blue); }
        .rep-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; margin-bottom: 8px; }
        .rep-label-small { font-size: 9px; font-weight: bold; color: var(--blue); margin-bottom: 2px; display: block; }
        .rep-input-compact { padding: 6px; border: 1px solid #90caf9; border-radius: 4px; background: white; font-weight: 900; font-size: 13px; text-align: center; color: var(--green); width: 100%; box-sizing: border-box; height: 32px; }
        .rep-display-compact { padding: 6px; border: 1px solid #4caf50; border-radius: 4px; background: white; font-weight: 900; font-size: 13px; text-align: center; color: var(--green); height: 32px; display: flex; align-items: center; justify-content: center; }

        .leave-panel { background: #f3e5f5; padding: 10px; border-bottom: 2px solid var(--purple); display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; }
        .leave-item { background: white; padding: 8px 4px; border-radius: 4px; text-align: center; border: 1px solid #d1c4e9; }
        .leave-count { font-size: 18px; font-weight: 900; color: var(--purple); line-height: 1; }
        .leave-name { font-size: 9px; font-weight: 900; color: #333; margin-top: 4px; display: block; }

        .weeks-banner { display: grid; grid-template-columns: repeat(5, 1fr); gap: 4px; padding: 8px; background: #fffde7; border-bottom: 3px solid var(--gold); }
        .w-tile { background: white; border: 1px solid #ccc; padding: 4px; border-radius: 4px; text-align: center; font-size: 9px; line-height: 1.2; }
        .w-val { font-weight: 900; font-size: 11px; display: block; color: var(--blue); }
        .w-diff { font-weight: 900; font-size: 11px; display: block; color: var(--red); }

        .penthemera-box { background: #fff3e0; padding: 10px; border-radius: 5px; margin: 10px 0; border-left: 5px solid #ff9800; }
        .penthemera-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .penthemera-item { background: white; padding: 8px; border-radius: 4px; text-align: center; }

        .repo-transfer-box { background: #e8f5e9; padding: 10px; border-radius: 5px; margin: 10px 0; border-left: 5px solid var(--green); }
        .repo-transfer-row { display: flex; justify-content: space-between; font-size: 13px; font-weight: bold; padding: 5px 0; }

        table { width: 100%; border-collapse: collapse; table-layout: fixed; }
        td { border: 1px solid #bbb; height: 110px; vertical-align: top; padding: 4px; cursor: pointer; background: white; overflow: hidden; }
        .sat-cell { background: var(--sat-bg) !important; }
        .sun-cell { background: var(--sun-bg) !important; }
        .holiday-cell { background: var(--hol-bg) !important; border: 2.5px solid var(--red) !important; }
        .day-num { font-weight: 900; font-size: 16px; display: block; }
        
        .shift-tag { color: white; font-size: 9px; padding: 2px; border-radius: 3px; display: block; margin-top: 2px; text-align: center; font-weight: bold; text-shadow: 0px 1px 1px rgba(0,0,0,0.3); }
        .tag-morning { background: var(--cls-morning); }
        .tag-afternoon { background: var(--cls-afternoon); }
        .tag-night { background: var(--cls-night); }
        .tag-repo10 { background: var(--cls-repo10); }
        .tag-leave { background: var(--cls-leave); }
        .tag-rest { background: var(--cls-rest); }
        .tag-custom { background: var(--blue); }

        .day-note { font-size: 11px; color: #000; font-weight: 900; display: block; margin-top: 4px; border-top: 1px solid #eee; }

        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); }
        .modal-content { background: white; width: 98%; max-width: 550px; margin: 5px auto; padding: 10px; border-radius: 8px; max-height: 95vh; overflow-y: auto; box-sizing: border-box; }
        .m-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 4px; margin-bottom: 10px; }
        .m-btn { padding: 10px 4px; border: 1px solid #ccc; background: #f5f5f5; font-weight: bold; font-size: 11px; cursor: pointer; }
        .shift-row { display: grid; grid-template-columns: 1.8fr 0.8fr 1fr; gap: 4px; margin-bottom: 6px; }
        .shift-row input { width: 100%; padding: 8px 4px; border: 1px solid #ccc; border-radius: 4px; font-weight: bold; font-size: 14px; box-sizing: border-box; }
        
        .footer { padding: 15px; background: #fafafa; border-top: 4px solid var(--green); }
        .money-line { display: flex; justify-content: space-between; border-bottom: 1px solid #eee; padding: 6px 0; font-size: 14px; font-weight: 900; }
        .total-net-box { background: var(--green); color: white; padding: 15px; text-align: center; font-size: 1.8em; font-weight: 900; border-radius: 8px; margin: 10px 0; }
        .active-shift { background: #2196f3 !important; color: white !important; }
        .custom-btn { background: #ffeb3b !important; color: #000 !important; }
        .btn-plus { background: var(--orange); color: white; border: none; padding: 2px 8px; border-radius: 4px; font-weight: bold; cursor: pointer; margin-left: 5px; }
        
        .update-btn { background: #4caf50; color: white; border: none; padding: 10px; border-radius: 4px; font-weight: bold; cursor: pointer; margin-top: 5px; width: 100%; }
        .version-badge { font-size: 10px; opacity: 0.8; margin-left: 5px; }
        .sync-status { font-size: 10px; margin-top: 5px; text-align: center; color: var(--green); }
        .backup-btns { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 10px; }
        .backup-btn { padding: 8px 4px; font-size: 11px; font-weight: bold; border-radius: 4px; border: none; cursor: pointer; }
        .btn-restore { background: #2196f3; color: white; }
        .btn-clean { background: #ff9800; color: white; }
    </style>
</head>
<body>
<div class="main-card">
    <div class="auth-panel" id="authPanel">
        <div class="user-info" id="userInfo">
            <div class="user-avatar" id="userAvatar">?</div>
            <span id="userEmail">Μη συνδεδεμένος</span>
            <span id="lastBackupSpan" class="last-backup"></span>
        </div>
        <div>
            <button class="auth-btn auth-btn-google" id="googleBtn" onclick="signInWithGoogle()">🔐 Google</button>
            <button class="auth-btn auth-btn-email" id="emailBtn" onclick="showLoginModal()">✉️ Email</button>
            <button class="auth-btn" id="logoutBtn" onclick="logout()" style="display:none;">🚪 Αποσύνδεση</button>
        </div>
    </div>
    
    <div id="loginModal" class="login-modal">
        <div class="login-card">
            <h3 id="loginTitle">Σύνδεση</h3>
            <div id="loginError" class="error-msg"></div>
            <input type="email" id="loginEmail" placeholder="Email">
            <input type="password" id="loginPassword" placeholder="Κωδικός">
            <button id="loginActionBtn" style="background:#4285f4; color:white;">Σύνδεση</button>
            <button id="registerBtn" style="background:#34a853; color:white;">Δημιουργία νέου λογαριασμού</button>
            <div class="toggle-mode" onclick="toggleLoginMode()">Δεν έχετε λογαριασμό; Εγγραφή</div>
            <button onclick="closeLoginModal()" style="background:#ccc;">Άκυρο</button>
        </div>
    </div>
    
    <div class="header">
        <div class="top-row">
            <b id="app-title">ΕΞ. ΦΡΟΥΡΑ - V7.3</b>
            <div><button onclick="nav(-1)">◄</button> <span id="month-label"></span> <button onclick="nav(1)">►</button></div>
        </div>
        <div style="font-size: 10px; margin-bottom: 2px;">ΕΒΔΟΜΑΔΙΑΙΟ ΩΡΑΡΙΟ:</div>
        <select id="mode-sel" onchange="saveMode()">
            <option value="34">34 ώρες</option>
            <option value="29">29 ώρες</option>
            <option value="24">24 ώρες</option>
        </select>
    </div>
    
    <div class="month-totals">
        <div class="total-box"><span class="total-label">ΣΤΟΧΟΣ</span><span class="total-val" id="m-target">0.0</span></div>
        <div class="total-box"><span class="total-label">ΠΕΝΘ/ΡΑ</span><span class="total-val" id="m-penthemera">0</span></div>
        <div class="total-box"><span class="total-label">ΝΥΧΤΕΣ</span><span class="total-val" id="m-night">0.0</span></div>
        <div class="total-box"><span class="total-label">ΡΕΠΟ ΣΚ</span><span class="total-val" id="m-repo">0</span></div>
    </div>
    
    <div class="rep-container">
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-bottom: 10px;">
            <div><span class="rep-label-small">ΜΕΙΩΜΕΝΟ</span>
                <select id="reduced-select" class="rep-input-compact" onchange="calculate()">
                    <option value="normal">Κανονικό</option>
                    <option value="minus1">-1 ώρα (-5 εβδ.)</option>
                    <option value="minus2">-2 ώρες (-10 εβδ.)</option>
                </select>
            </div>
            <div><span class="rep-label-small">ΠΛΗΡΩΜΕΝΕΣ (ώρες)</span>
                <input type="number" id="paidHours" class="rep-input-compact" value="0" onchange="savePaidHours()">
            </div>
        </div>
        <div class="rep-grid">
            <div><span class="rep-label-small">ΠΡ/ΜΗΝ (ώρες)</span><input type="number" id="prminRepInput" class="rep-input-compact" onchange="manualPrevMonthChange()"></div>
            <div><span class="rep-label-small">ΜΕΤΑΦΟΡΑ (ώρες)</span><div id="transferRep" class="rep-display-compact" style="color:var(--orange)">0</div></div>
        </div>
        <button onclick="saveRepTransfer()" style="width:100%; padding:10px; background:var(--blue); color:white; border:none; border-radius:4px; font-weight:bold; margin-top:5px;">ΑΠΟΘΗΚΕΥΣΗ ΡΕΠΟ</button>
        <button onclick="syncToCloud()" id="cloudSyncBtn" style="width:100%; padding:8px; background:var(--gold); color:#333; border:none; border-radius:4px; font-weight:bold; margin-top:5px;">☁️ Αποθήκευση στο Cloud</button>
        <div id="syncStatus" class="sync-status"></div>
    </div>
    
    <div class="leave-panel">
        <div class="leave-item"><div class="leave-count" id="leave-normal">0</div><div class="leave-name">ΚΑΝΟΝΙΚΗ (34)</div></div>
        <div class="leave-item"><div class="leave-count" id="leave-short">0</div><div class="leave-name">ΒΡΑΧΕΙΑ (11)</div></div>
        <div class="leave-item"><div class="leave-count" id="leave-sick">0</div><div class="leave-name">ΑΝΑΡΡΩΤΙΚΗ</div></div>
        <div class="leave-item"><div class="leave-count" id="leave-special">0</div><div class="leave-name">ΕΙΔΙΚΗ</div></div>
    </div>

    <div class="weeks-banner" id="weeks-stats"></div>

    <div class="penthemera-box">
        <div class="penthemera-grid">
            <div class="penthemera-item"><div style="font-size: 11px; font-weight: bold;">Πενθήμερα <button class="btn-plus" onclick="addExtraPent()">+</button></div><div id="p-count" style="font-size: 16px; font-weight: 900;">0</div><div id="p-extra-label" style="font-size: 9px; color: var(--orange);"></div></div>
            <div class="penthemera-item"><div style="font-size: 11px; font-weight: bold;">Μεικτό (46€)</div><div id="p-gross" style="font-size: 16px; font-weight: 900;">0.00€</div></div>
            <div class="penthemera-item"><div style="font-size: 11px; font-weight: bold;">Εισφορά 2%</div><div id="p-eis" style="font-size: 14px; color: var(--red);">0.00€</div></div>
            <div class="penthemera-item"><div style="font-size: 11px; font-weight: bold;">Φόρος 20%</div><div id="p-tax" style="font-size: 14px; color: var(--red);">0.00€</div></div>
            <div class="penthemera-item" style="grid-column: span 2; background: #e8f5e9;"><div style="font-size: 11px; font-weight: bold;">ΚΑΘΑΡΟ ΠΕΝΘΗΜΕΡΩΝ</div><div id="p-net" style="font-size: 20px; font-weight: 900; color: var(--green);">0.00€</div></div>
        </div>
    </div>

    <div class="repo-transfer-box">
